# Auto-detect text files and normalize to LF in the repository
* text=auto

# Shell scripts (Linux)
*.sh text eol=lf

# Docker
Dockerfile text eol=lf
.dockerignore text eol=lf

# Kubernetes & YAML
*.yml text eol=lf
*.yaml text eol=lf

# Python
*.py text eol=lf

# PowerShell scripts (Windows)
*.ps1 text eol=crlf

# Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf

# Markdown
*.md text eol=lf

# GitHub Actions workflows
.github/workflows/*.yml text eol=lf